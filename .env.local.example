# Supabase（https://supabase.com で無料作成）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxx
SUPABASE_SERVICE_ROLE_KEY=xxxx

# PayPay（https://developer.paypay.ne.jp で加盟店登録後に取得）
PAYPAY_CLIENT_ID=xxxx
PAYPAY_CLIENT_SECRET=xxxx
PAYPAY_MERCHANT_ID=xxxx
PAYPAY_SANDBOX=true   # 本番は false に変更

# アプリのURL（Vercelデプロイ後は実際のURLに変更）
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 管理画面パスワード（任意の文字列に変更してください）
ADMIN_PASSWORD=changeme
